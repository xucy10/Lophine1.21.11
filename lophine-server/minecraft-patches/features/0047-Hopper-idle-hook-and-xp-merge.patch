Subject: [PATCH] Hopper idle hook and XP orb merge optimization

Add idle skip check to HopperBlockEntity.pushItemsTick and enhanced
merge interval + cross-value merge to ExperienceOrb.tick.

diff --git a/net/minecraft/world/level/block/entity/HopperBlockEntity.java b/net/minecraft/world/level/block/entity/HopperBlockEntity.java
index 97fa3bc130983aa7ead94c0a6b9335e289c6bc8a..0000000000000000000000000000000000000000 100644
--- a/net/minecraft/world/level/block/entity/HopperBlockEntity.java
+++ b/net/minecraft/world/level/block/entity/HopperBlockEntity.java
@@ -174,9 +174,10 @@ public class HopperBlockEntity extends RandomizableContainerBlockEntity implemen
     public static void pushItemsTick(Level level, BlockPos pos, BlockState state, HopperBlockEntity blockEntity) {
         blockEntity.cooldownTime--;
         blockEntity.tickedGameTime = level.getRedstoneGameTime(); // Folia - region threading
+        if (fun.bm.lophine.util.HopperIdleHelper.shouldSkipTick(blockEntity, level)) return; // Lophine - hopper idle optimization
         if (!blockEntity.isOnCooldown()) {
             blockEntity.setCooldown(0);
             // Spigot start
             boolean result = tryMoveItems(level, pos, state, blockEntity, () -> {
                 return suckInItems(level, blockEntity);
diff --git a/net/minecraft/world/entity/ExperienceOrb.java b/net/minecraft/world/entity/ExperienceOrb.java
index 34dc71daf2182805465742b1455e13b904f076e9..0000000000000000000000000000000000000000 100644
--- a/net/minecraft/world/entity/ExperienceOrb.java
+++ b/net/minecraft/world/entity/ExperienceOrb.java
@@ -165,7 +165,10 @@ public class ExperienceOrb extends Entity {
             if (this.tickCount % 20 == 1) {
                 this.scanForMerges();
             }
+            int lophineMergeInterval = fun.bm.lophine.config.modules.misc.ItemEntityPerfConfig.xpOrbMergeInterval; // Lophine - xp merge optimization
+            if (lophineMergeInterval > 0 && this.tickCount % lophineMergeInterval == 0) {
+                fun.bm.lophine.util.XpOrbMergeHelper.enhancedMerge(this); // Lophine - xp merge optimization
+            }
 
             this.followNearbyPlayer();
             if (this.followingPlayer == null && !this.level().isClientSide() && flag) {